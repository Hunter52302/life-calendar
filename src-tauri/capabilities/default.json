{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the main window: window controls, updater, notifications, dialogs, and opening external links.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-unminimize",
    "core:window:allow-set-focus",
    "opener:default",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "dialog:default",
    "notification:default"
  ]
}
