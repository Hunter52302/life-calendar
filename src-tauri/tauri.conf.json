{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PLS Calendar",
  "version": "1.0.15",
  "identifier": "com.plscalendar.app",

  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",

    "beforeDevCommand": "npm run dev",

    "beforeBuildCommand": "npm run build"
  },

  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PLS Calendar",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },

  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxMDExNTQ1RDlCNEU5NDkKUldSSjZiVFpSUlVCMGRyY3ZWRFdmdWFQTUlTQUd0Wlp3djhZc0UrYWxkYXE3bG1aNEtEMHVGTW4K",
      "endpoints": [
        "https://github.com/Hunter52302/life-calendar/releases/latest/download/latest.json"
      ]
    }
  }
}
