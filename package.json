    "pb:migrate:collections": "./pocketbase/pocketbase migrate collections --migrationsDir=./pocketbase/pb_migrations",
    "pb:migrate:history-sync": "./pocketbase/pocketbase migrate history-sync --migrationsDir=./pocketbase/pb_migrations",
    "build": "vite build",
    "lint": "eslint .",
    "test": "node --test \"src/**/*.test.js\"",
