# Copy this file to .env and fill in your values.
# .env is git-ignored so your keys are never committed.

# ── Maps & Drive Times ───────────────────────────────────────────────────────
# Drive times use the OPEN-SOURCE stack by default — no key, no fees:
#   geocoding → OpenStreetMap Nominatim
#   routing   → OSRM public server (router.project-osrm.org)
#
# OPTIONAL: set a Google Maps key to add real-time traffic data and act as
# a fallback when OSRM is unreachable. Enable "Directions API" and
# "Geocoding API" at https://console.cloud.google.com/ if you do.
# GOOGLE_MAPS_API_KEY=your_key_here

# ── JWT ──────────────────────────────────────────────────────────────────────
# Secret used to sign auth tokens. Generate with: openssl rand -hex 32
# Required — server will reject all authenticated requests without this.
# Also the basis for encrypting stored OAuth calendar tokens (a separate key is
# derived from it) — rotating this secret means users must reconnect calendars.
JWT_SECRET=change_me_to_a_random_secret

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on (defaults to 3001 if not set)
# PORT=3001

# ── PocketBase ───────────────────────────────────────────────────────────────
# Local PocketBase base URL used by the server's PocketBase-backed event sync.
# Default is http://127.0.0.1:8090 when unset.
# POCKETBASE_URL=http://127.0.0.1:8090

# ── Google Calendar OAuth (optional — "Connect Google" in Connected Calendars) ─
# Lets users import & auto-sync a Google Calendar without pasting a secret URL.
# Setup:
#   1. https://console.cloud.google.com/ → create/select a project
#   2. APIs & Services → Library → enable "Google Calendar API"
#   3. OAuth consent screen → External → add yourself under Test users
#   4. Credentials → Create OAuth client ID → Web application
#      → Authorized redirect URI: http://localhost:3001/api/oauth/google/callback
#        (use your real server URL in production)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ── Microsoft Calendar OAuth (optional — Outlook / Microsoft 365) ──────────────
# Setup:
#   1. https://portal.azure.com/ → Microsoft Entra ID → App registrations → New
#      → Supported accounts: "any org directory and personal Microsoft accounts"
#      → Redirect URI (Web): http://localhost:3001/api/oauth/microsoft/callback
#   2. API permissions → Microsoft Graph → Delegated → Calendars.Read,
#      offline_access, User.Read
#   3. Certificates & secrets → New client secret → copy its VALUE
# MS_OAUTH_CLIENT_ID=
# MS_OAUTH_CLIENT_SECRET=

# Base URL the OAuth providers redirect back to (defaults to http://localhost:<PORT>).
# Set in production to match the redirect URI registered with Google/Microsoft.
# OAUTH_CALLBACK_BASE_URL=https://yourserver.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# During mobile development add the Expo Metro server origin.
# FRONTEND_URL=http://localhost:5173,http://localhost:8081
# In production:
# FRONTEND_URL=https://yourapp.com

# ── Web Frontend (Vite) ───────────────────────────────────────────────────────
# API base URL for the web app. Not needed in development — Vite proxies
# /api to localhost:3001 automatically. Set this for production deploys
# where the web app and server run on different domains.
# VITE_API_URL=https://api.yourapp.com/api

# ── Infisical (optional — secrets vault) ─────────────────────────────────────
# If set, API keys are fetched from Infisical at request time with a 5-min cache.
# Without these, keys fall back to process.env values below.
#
# Setup:
# 1. Create a project at https://app.infisical.com (free) or self-host
# 2. Go to Access Control → Machine Identities → Universal Auth
# 3. Copy Client ID and Client Secret
# 4. Set INFISICAL_PROJECT_ID from your project's Settings page
#
# INFISICAL_CLIENT_ID=your_machine_identity_client_id
# INFISICAL_CLIENT_SECRET=your_machine_identity_client_secret
# INFISICAL_PROJECT_ID=your_project_id
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_URL=https://your-infisical.com   # self-hosted only

# ── Capacitor (iOS / Android) ────────────────────────────────────────────────
# When building for Capacitor (native iOS/Android), the device cannot reach
# "localhost" — it needs the server's real address.
#
# For development (device on same LAN as your Mac):
#   1. Find your Mac's LAN IP: System Settings → Wi-Fi → Details
#   2. Set VITE_API_URL to http://<your-mac-ip>:3001/api
#   3. Run: npm run build && npm run cap:sync
#
# For production (self-hosted):
#   VITE_API_URL=https://yourserver.com/api
#
# VITE_API_URL=http://192.168.1.x:3001/api

# ── Bot-signup protection (optional) ─────────────────────────────────────────
# Cloudflare Turnstile (free tier, privacy-respecting) on /api/auth/register.
# When unset, registration has no CAPTCHA check at all (rate limiting still
# applies). Get a site key + secret at https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SECRET=

# ── Mobile App (Expo) ────────────────────────────────────────────────────────
# This variable lives in mobile/.env (not this file).
# See mobile/.env.example for Expo-specific config.
# EXPO_PUBLIC_API_URL=http://192.168.1.x:3001/api
