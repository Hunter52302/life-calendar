# Copy this file to .env and fill in your values.
# .env is git-ignored so your keys are never committed.

# ── Google Maps ──────────────────────────────────────────────────────────────
# Single key used by ALL Google Maps routes:
#   /api/drive-time       → Directions API
#   /api/geocode/google   → Geocoding API
#
# Setup:
# 1. Go to https://console.cloud.google.com/
# 2. Create (or select) a project
# 3. Enable BOTH "Directions API" AND "Geocoding API"
#    (APIs & Services → Library → search each one → Enable)
# 4. Create an API key under APIs & Services → Credentials
# 5. Restrict the key to your server's IP in production
#
# Free tier: ~40,000 requests/month per API before charges apply.
# Billing must be enabled on the project before any key will work.
#
# NOTE: /api/geocode/nominatim uses OpenStreetMap and needs NO key at all.
GOOGLE_MAPS_API_KEY=your_key_here

# ── JWT ──────────────────────────────────────────────────────────────────────
# Secret used to sign auth tokens. Generate with: openssl rand -hex 32
# Required — server will reject all authenticated requests without this.
JWT_SECRET=change_me_to_a_random_secret

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on (defaults to 3001 if not set)
# PORT=3001

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# During mobile development add the Expo Metro server origin.
# FRONTEND_URL=http://localhost:5173,http://localhost:8081
# In production:
# FRONTEND_URL=https://yourapp.com

# ── Web Frontend (Vite) ───────────────────────────────────────────────────────
# API base URL for the web app. Not needed in development — Vite proxies
# /api to localhost:3001 automatically. Set this for production deploys
# where the web app and server run on different domains.
# VITE_API_URL=https://api.yourapp.com/api

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate a key pair once with: node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()));"
# Then paste the output here. Required for browser push notifications.
# VAPID_PUBLIC_KEY=BExamplePublicKey...
# VAPID_PRIVATE_KEY=ExamplePrivateKey...
# VAPID_SUBJECT=mailto:you@example.com

# ── Discord Bot (optional — Phase 2) ─────────────────────────────────────────
# Only needed if you want two-way Discord slash commands (/today, /habits).
# Create an Application at https://discord.com/developers/applications
# DISCORD_APPLICATION_ID=
# DISCORD_PUBLIC_KEY=
# DISCORD_BOT_TOKEN=

# ── Mobile App (Expo) ────────────────────────────────────────────────────────
# This variable lives in mobile/.env (not this file).
# See mobile/.env.example for Expo-specific config.
# EXPO_PUBLIC_API_URL=http://192.168.1.x:3001/api
