# Copy this file to .env and fill in your values.
# .env is git-ignored so your keys are never committed.

# ── Maps & Drive Times ───────────────────────────────────────────────────────
# Automatic drive-time buffers use a FREE, open-source stack:
#   geocoding → OpenStreetMap Nominatim   (no key)
#   routing   → OpenRouteService          (free key, 2,000 requests/day)
#
# Get a free ORS key (no billing account) at https://openrouteservice.org/dev/
# and set it below. Without it, the "Estimate drive time" button returns a
# "not configured" message and users can still enter buffer minutes manually.
# ORS_API_KEY=your_openrouteservice_key
#
# OPTIONAL: a Google Maps key can later add real-time traffic data.
# GOOGLE_MAPS_API_KEY=your_key_here

# ── JWT ──────────────────────────────────────────────────────────────────────
# Secret used to sign auth tokens. Generate with: openssl rand -hex 32
# Required — server will reject all authenticated requests without this.
# Also the basis for encrypting stored OAuth calendar tokens (a separate key is
# derived from it) — rotating this secret means users must reconnect calendars.
JWT_SECRET=change_me_to_a_random_secret

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on (defaults to 3001 if not set)
# PORT=3001

# ── PocketBase ───────────────────────────────────────────────────────────────
# Local PocketBase base URL used by the server's PocketBase-backed event sync.
# Default is http://127.0.0.1:8090 when unset.
# POCKETBASE_URL=http://127.0.0.1:8090
#
# REQUIRED: PocketBase superuser credentials. All collection API rules are
# locked to superuser-only (see pb_migrations/*_lock_collection_rules.js), so
# the Express server authenticates as this superuser to read/write data. Without
# these, every data request fails closed. This is what keeps the data layer
# (auth envelopes, secrets, OAuth tokens, user data) unreachable by anyone who
# can hit the PocketBase port.
#
# Create the superuser once, then set the same values here:
#   ./pocketbase/pocketbase superuser upsert admin@yourdomain.com "a-long-random-password"
#
# Also: never expose the PocketBase port (8090) to the internet or proxy it
# publicly — nginx should only proxy /api to the Express server (port 3001).
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=

# ── Google OAuth (optional — calendar sync + "Sign in with Google") ────────────
# The same credentials power BOTH "Connect Google" (calendar import/sync) and
# "Sign in with Google" (linked login: link it in Settings, then sign in either
# way — password + recovery code keep working, so losing Google won't lock you
# out). Linking Google also sets up calendar sync in one consent.
# Setup:
#   1. https://console.cloud.google.com/ → create/select a project
#   2. APIs & Services → Library → enable "Google Calendar API"
#   3. OAuth consent screen → External → add yourself under Test users
#   4. Credentials → Create OAuth client ID → Web application
#      → Add ALL THREE Authorized redirect URIs (use your real server URL in prod):
#          http://localhost:3001/api/oauth/google/callback           (calendar connect)
#          http://localhost:3001/api/auth/google/link/callback       (link Google login)
#          http://localhost:3001/api/auth/google/login/callback      (sign in with Google)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ── Microsoft Calendar OAuth (optional — Outlook / Microsoft 365) ──────────────
# Setup:
#   1. https://portal.azure.com/ → Microsoft Entra ID → App registrations → New
#      → Supported accounts: "any org directory and personal Microsoft accounts"
#      → Redirect URI (Web): http://localhost:3001/api/oauth/microsoft/callback
#   2. API permissions → Microsoft Graph → Delegated → Calendars.Read,
#      offline_access, User.Read
#   3. Certificates & secrets → New client secret → copy its VALUE
# MS_OAUTH_CLIENT_ID=
# MS_OAUTH_CLIENT_SECRET=

# Base URL the OAuth providers redirect back to (defaults to http://localhost:<PORT>).
# Set in production to match the redirect URI registered with Google/Microsoft.
# OAUTH_CALLBACK_BASE_URL=https://yourserver.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# During mobile development add the Expo Metro server origin.
# FRONTEND_URL=http://localhost:5173,http://localhost:8081
# In production:
# FRONTEND_URL=https://yourapp.com

# ── Web Frontend (Vite) ───────────────────────────────────────────────────────
# API base URL for the web app. Not needed in development — Vite proxies
# /api to localhost:3001 automatically. Set this for production deploys
# where the web app and server run on different domains.
# VITE_API_URL=https://api.yourapp.com/api

# ── Infisical (optional — secrets vault) ─────────────────────────────────────
# If set, API keys are fetched from Infisical at request time with a 5-min cache.
# Without these, keys fall back to process.env values below.
#
# Setup:
# 1. Create a project at https://app.infisical.com (free) or self-host
# 2. Go to Access Control → Machine Identities → Universal Auth
# 3. Copy Client ID and Client Secret
# 4. Set INFISICAL_PROJECT_ID from your project's Settings page
#
# INFISICAL_CLIENT_ID=your_machine_identity_client_id
# INFISICAL_CLIENT_SECRET=your_machine_identity_client_secret
# INFISICAL_PROJECT_ID=your_project_id
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_URL=https://your-infisical.com   # self-hosted only

# ── Capacitor (iOS / Android) ────────────────────────────────────────────────
# When building for Capacitor (native iOS/Android), the device cannot reach
# "localhost" — it needs the server's real address.
#
# For development (device on same LAN as your Mac):
#   1. Find your Mac's LAN IP: System Settings → Wi-Fi → Details
#   2. Set VITE_API_URL to http://<your-mac-ip>:3001/api
#   3. Run: npm run build && npm run cap:sync
#
# For production (self-hosted):
#   VITE_API_URL=https://yourserver.com/api
#
# VITE_API_URL=http://192.168.1.x:3001/api

# ── Desktop-app releases (optional — private repo distribution) ──────────────
# The "Download Desktop App" menu lists GitHub Releases through the backend so
# downloads keep working while the repo is PRIVATE (anonymous GitHub calls 404
# on a private repo). The token stays server-side and is never sent to browsers.
#
# Setup:
#   1. https://github.com/settings/tokens?type=beta → Generate new token
#   2. Resource owner: your account · Repository access: only life-calendar
#   3. Permissions → Repository → Contents: Read-only  (that's all it needs)
#   4. Paste the token below. Omit to hide/disable the download list.
# GITHUB_RELEASES_REPO=Hunter52302/life-calendar
# GITHUB_RELEASES_TOKEN=github_pat_...

# ── Bot-signup protection (optional) ─────────────────────────────────────────
# Cloudflare Turnstile (free tier, privacy-respecting) on /api/auth/register.
# When unset, registration has no CAPTCHA check at all (rate limiting still
# applies). Get a site key + secret at https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SECRET=

# ── Web Push notifications (recommended) ──────────────────────────────────────
# Powers browser push on desktop (Chrome/Edge/Firefox/Safari 16+) and installed
# PWAs — including iOS/iPadOS 16.4+ once the app is Added to the Home Screen.
# Without these keys, /api/push/vapid-public-key answers 503 and the in-app
# "Enable" button for Browser Push can't subscribe; every other channel still
# works. Requires the site to be served over HTTPS (or localhost).
#
# Generate a key pair once:   npm run vapid:keys
# then paste the output below and restart the API. Keep the private key secret
# and stable — rotating it invalidates every existing browser subscription.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com   # mailto: or https: contact for push services

# ── E-mail notifications (optional) ──────────────────────────────────────────
# Lets users add an "Email" notification integration (reminders, daily summary,
# habit check-ins). Any standard SMTP provider works (Gmail app-password,
# Fastmail, SES, Postmark, Mailgun, a self-hosted relay, …). When SMTP_HOST is
# unset, the Email integration type is simply skipped — everything else keeps
# working. Only timing text is sent by default; event labels require an
# Integration Hint, same as the Discord/Slack channels.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587                      # 465 = implicit TLS, 587 = STARTTLS (default 587)
# SMTP_SECURE=                       # "true"/"false" to override the port-based default
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=PLS Calendar <no-reply@example.com>   # defaults to SMTP_USER

# ── SMS notifications (optional, via Twilio) ─────────────────────────────────
# Lets users add an "SMS" notification integration, delivered through Twilio.
# When TWILIO_ACCOUNT_SID is unset, the SMS integration type is simply skipped —
# everything else keeps working. Only timing text is sent by default; event
# labels require an Integration Hint, same as the other channels.
#
# Create an account + a Messaging-capable number at https://twilio.com. Note:
# US app-to-person traffic must be registered (A2P 10DLC) or carriers will
# filter it, and standard per-message SMS rates apply.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15551234567     # your Twilio number in E.164 format
#
# Free stopgap (no Twilio account): most US carriers accept e-mail-to-SMS
# gateways — e.g. 5551234567@vtext.com (Verizon), @txt.att.net (AT&T),
# @tmomail.net (T-Mobile). Add one as an *Email* integration instead. It costs
# nothing and needs no extra config, but deliverability is carrier-dependent.

# ── Mobile App (Expo) ────────────────────────────────────────────────────────
# This variable lives in mobile/.env (not this file).
# See mobile/.env.example for Expo-specific config.
# EXPO_PUBLIC_API_URL=http://192.168.1.x:3001/api
