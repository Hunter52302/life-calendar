{
  "expo": {
    "name": "PLS Calendar",
    "slug": "pls-calendar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "pls-calendar",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/102f8f2e-d692-4f96-b460-9cbc2a38064c"
    },
    "plugins": [
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsText": true
          },
          "androidIntentFilters": ["text/*"]
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow PLS Calendar to use the microphone for voice event input.",
          "speechRecognitionPermission": "Allow PLS Calendar to use speech recognition for voice event input.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow PLS Calendar to link a contact you pick to an event."
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hunter52302.plscalendar",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hunter52302.plscalendar",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "102f8f2e-d692-4f96-b460-9cbc2a38064c"
      }
    },
    "owner": "hunter52302"
  }
}
