# Copy to mobile/.env and set your dev machine's LAN IP.
# Emulators and physical devices cannot reach the host via "localhost" —
# you must use the machine's actual LAN IP address.
#
# Find your LAN IP:
#   macOS:  ipconfig getifaddr en0
#   Linux:  hostname -I | awk '{print $1}'
#
EXPO_PUBLIC_API_URL=http://192.168.1.x:3001/api
